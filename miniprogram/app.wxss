page { --primary: #8B5E3C; --primary-light: #c49a6c; --bg: #fdf6f0; --bg-light: #fdfaf7; --border: #e8d5c4; --text: #3e2e23; --text-light: #a08060; --danger: #c44; --success: #4a8; --warning: #e8a838; background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
.container { max-width: 800px; margin: 0 auto; padding: 24px 20px; }
.card { background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(139,94,60,0.1); padding: 28px; margin-bottom: 20px; }
