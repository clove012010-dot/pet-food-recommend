.profile-bar { display: flex; align-items: center; gap: 12px; padding: 14px 18px; }
.profile-current { flex: 1; display: flex; align-items: center; gap: 8px; }
.profile-label { font-size: 12px; color: var(--text-light); white-space: nowrap; }
.profile-name-input { border: none; background: transparent; font-size: 16px; font-weight: 600; color: var(--text); flex: 1; padding: 2px 4px; }
.profile-count { background: var(--bg); color: var(--text-light); font-size: 11px; padding: 2px 8px; border-radius: 10px; }
.profile-actions { display: flex; align-items: center; gap: 6px; }
.profile-empty { border: 2px dashed var(--border); background: #fffdf8; display: flex; justify-content: center; }
.empty-box { text-align: center; padding: 20px; color: var(--text-light); }
.empty-icon { font-size: 32px; }
.btn-sm { padding: 5px 10px; border: 2px solid var(--border); border-radius: 8px; background: #fff; color: var(--primary); font-size: 13px; }
.btn-primary { background: var(--primary); color: #fff; border-radius: 8px; padding: 8px 20px; font-size: 14px; }
.btn-danger { color: var(--danger); }
.btn-submit { width: 100%; padding: 14px; background: var(--primary); color: #fff; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; margin-top: 8px; }
.tab-bar { display: flex; margin: 0 0 12px; background: #fff; border-radius: 12px; overflow: hidden; }
.tab-btn { flex: 1; text-align: center; padding: 12px 8px; font-size: 14px; font-weight: 600; color: var(--text-light); border-bottom: 3px solid transparent; }
.tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); background: #fff; }
.tab-panel { display: block; }
.form-row { display: flex; gap: 14px; margin-bottom: 14px; flex-wrap: wrap; }
.form-group { flex: 1; min-width: 160px; }
.form-group input { width: 100%; padding: 9px 12px; border: 2px solid var(--border); border-radius: 10px; font-size: 14px; }
.label { display: block; font-size: 13px; color: var(--primary); margin-bottom: 5px; font-weight: 600; }
.picker { padding: 9px 12px; border: 2px solid var(--border); border-radius: 10px; font-size: 14px; color: var(--text); background: #fdfaf7; }
.h2 { font-size: 18px; color: var(--primary); margin-bottom: 18px; padding-bottom: 10px; border-bottom: 2px solid var(--bg); display: block; }
.cb-item { margin-right: 12px; font-size: 13px; }
.food-card { background: #fff; border: 1px solid var(--bg); border-radius: 12px; padding: 14px; margin-bottom: 12px; box-shadow: 0 2px 6px rgba(139,94,60,0.06); }
.food-header { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 8px; }
.food-title-wrap { flex: 1; min-width: 0; }
.food-name { font-size: 15px; color: var(--text); font-weight: 600; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; }
.food-score { font-size: 22px; font-weight: 700; color: var(--primary); white-space: nowrap; flex-shrink: 0; }
.food-score-unit { font-size: 11px; color: var(--text-light); font-weight: 400; margin-left: 2px; }
.food-desc { font-size: 12px; color: #6b5b4f; line-height: 1.5; margin: 4px 0 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.nutrition-grid { display: flex; gap: 6px; margin: 8px 0; }
.n-item { flex: 1; text-align: center; padding: 8px 4px; background: var(--bg); border-radius: 6px; }
.n-val { font-size: 15px; font-weight: 700; color: var(--primary); display: block; }
.n-label { font-size: 10px; color: var(--text-light); margin-top: 2px; display: block; }
.feed-guide { font-size: 12px; color: var(--success); display: block; margin-top: 8px; background: #f0f7f0; padding: 8px 12px; border-radius: 6px; border-left: 3px solid var(--success); }
.chart-table { margin: 8px 0; font-size: 11px; border: 1px solid var(--bg); border-radius: 6px; overflow: hidden; }
.chart-row { display: flex; padding: 4px 6px; border-bottom: 1px solid var(--bg); }
.chart-row text { flex: 1; text-align: center; }
.chart-head { background: var(--bg); font-weight: 600; }
.insight-box { background: #e8f4fd; border-left: 4px solid #5b9bd5; padding: 12px 16px; border-radius: 8px; margin-bottom: 14px; }
.insight-item { font-size: 13px; color: var(--text); line-height: 1.8; display: block; }
.h3 { font-size: 15px; color: var(--primary); margin-bottom: 8px; display: block; font-weight: 600; }
.diary-row { display: flex; justify-content: space-between; align-items: center; padding: 8px; border-bottom: 1px solid var(--bg); font-size: 12px; }
.alert-card { padding: 10px 14px; border-radius: 8px; margin-bottom: 8px; font-size: 13px; }
.alert-warning { background: #fff8e1; border: 1px solid #ffe082; }
.alert-danger { background: #fde8e8; border: 1px solid #f5c6c6; }
