<!-- 档案栏 -->
<view class="profile-bar card" wx:if="{{profiles.length > 0}}">
  <view class="profile-current">
    <text class="profile-label">当前档案</text>
    <input value="{{activeProfile.name}}" bindblur="onProfileNameSave" class="profile-name-input" />
    <text class="profile-count">{{activeIdx}}/{{profiles.length}}</text>
  </view>
  <view class="profile-actions">
    <picker bindchange="onSwitchProfile" value="{{activeIdx}}" range="{{profileNames}}">
      <view class="btn-sm">{{activeProfile.name || '选择'}}</view>
    </picker>
    <button class="btn-sm" bindtap="onNewProfile">➕</button>
    <button class="btn-sm" bindtap="onCopyProfile">📋</button>
    <button class="btn-sm" bindtap="onSaveProfile">💾</button>
    <button class="btn-sm btn-danger" bindtap="onDeleteProfile">🗑</button>
  </view>
</view>
<view class="profile-empty card" wx:else>
  <view class="empty-box">
    <text class="empty-icon">🐾</text>
    <text>还没有宠物档案</text>
    <button class="btn-primary" bindtap="onNewProfile">🐾 创建第一个档案</button>
  </view>
</view>

<!-- Tab 导航 -->
<view class="tab-bar">
  <view class="tab-btn {{currentTab==='recommend'?'active':''}}" bindtap="onSwitchTab" data-tab="recommend">📋 推荐</view>
  <view class="tab-btn {{currentTab==='feeding'?'active':''}}" bindtap="onSwitchTab" data-tab="feeding">🍽 喂食</view>
  <view class="tab-btn {{currentTab==='vaccination'?'active':''}}" bindtap="onSwitchTab" data-tab="vaccination">💉 疫苗</view>
</view>

<!-- 推荐面板 -->
<view wx:if="{{currentTab==='recommend'}}" class="tab-panel">
  <view class="card">
    <text class="h2">📋 基本信息</text>
    <view class="form-row">
      <view class="form-group">
        <text class="label">宠物种类</text>
        <picker bindchange="onSpeciesChange" value="{{speciesIdx}}" range="{{speciesOptions}}">
          <view class="picker">{{speciesIdx >= 0 ? speciesOptions[speciesIdx] : '请选择'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="label">品种</text>
        <picker bindchange="onBreedChange" value="{{breedIdx}}" range="{{breedNames}}" disabled="{{breedIdx < 0 && breedNames.length === 0}}">
          <view class="picker">{{breedIdx >= 0 ? breedNames[breedIdx] : (breedNames.length > 0 ? '请选择' : '请先选种类')}}</view>
        </picker>
      </view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">年龄(月)</text><input value="{{formData.ageMonths}}" bindinput="onInput" data-field="ageMonths" type="number" /></view>
      <view class="form-group"><text class="label">体重(kg)</text><input value="{{formData.weightKg}}" bindinput="onInput" data-field="weightKg" type="digit" /></view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">性别</text><picker bindchange="onSexChange" value="{{sexIdx}}" range="{{sexOptions}}"><view class="picker">{{sexOptions[sexIdx]}}</view></picker></view>
      <view class="form-group"><text class="label">绝育</text><picker bindchange="onNeuteredChange" value="{{nuteredIdx}}" range="{{nuteredOptions}}"><view class="picker">{{nuteredOptions[nuteredIdx]}}</view></picker></view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">体态评分</text><picker bindchange="onBcsChange" value="{{bcsIdx}}" range="{{bcsOptions}}"><view class="picker">{{bcsOptions[bcsIdx]}}</view></picker></view>
      <view class="form-group"><text class="label">活动量</text><picker bindchange="onActivityChange" value="{{activityIdx}}" range="{{activityOptions}}"><view class="picker">{{activityOptions[activityIdx]}}</view></picker></view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">预算</text><picker bindchange="onBudgetChange" value="{{budgetIdx}}" range="{{budgetOptions}}"><view class="picker">{{budgetOptions[budgetIdx]}}</view></picker></view>
      <view class="form-group"><text class="label">护理目标</text><picker bindchange="onGoalChange" value="{{goalIdx}}" range="{{goalOptions}}"><view class="picker">{{goalOptions[goalIdx]}}</view></picker></view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">粮食品类</text>
        <checkbox-group bindchange="onFoodTypeChange">
          <label wx:for="{{foodTypeOptions}}" wx:key="*this" class="cb-item">
            <checkbox value="{{item}}" checked="{{!!foodTypeChecked[item]}}" />{{item}}
          </label>
        </checkbox-group>
        <text class="form-hint">{{foodTypeCheckedHint}}</text>
      </view>
    </view>
    <button class="btn-submit" bindtap="onSubmit">🔍 为我推荐</button>
  </view>

  <!-- 推荐结果 -->
  <view wx:if="{{showResults}}" class="card">
    <text class="h2">🏆 推荐结果</text>
    <view wx:if="{{profileInsights && profileInsights.length > 0}}" class="insight-box">
      <text class="h3">📊 品种分析</text>
      <view wx:for="{{profileInsights}}" wx:key="*this" class="insight-item">
        <text>· {{item}}</text>
      </view>
    </view>
    <view wx:for="{{recommendations}}" wx:key="id" class="food-card">
      <view class="food-header">
        <view class="food-title-wrap">
          <text class="food-name">{{item.brand}} · {{item.name}}</text>
        </view>
        <text class="food-score">{{item.totalScore}}<text class="food-score-unit">分</text></text>
      </view>
      <text class="food-desc">{{item.desc}}</text>
      <view class="nutrition-grid">
        <view class="n-item"><text class="n-val">{{item.protein}}%</text><text class="n-label">蛋白</text></view>
        <view class="n-item"><text class="n-val">{{item.fat}}%</text><text class="n-label">脂肪</text></view>
        <view class="n-item"><text class="n-val">{{item.phosphorus}}%</text><text class="n-label">磷</text></view>
        <view class="n-item"><text class="n-val">{{item.calorie_per_100g}}</text><text class="n-label">kcal</text></view>
      </view>
      <text class="feed-guide">建议每日{{item.feedingGuide.gramsPerDay}}g × {{item.feedingGuide.mealsPerDay}}餐</text>
    </view>
  </view>
</view>

<!-- 喂食面板 -->
<view wx:if="{{currentTab==='feeding'}}" class="tab-panel">
  <view class="card">
    <text class="h2">🍽 喂食日记</text>
    <text style="font-size:13px;color:var(--text-light);margin-bottom:12px">{{feedHint}}</text>
    <view class="form-row">
      <view class="form-group"><text class="label">日期</text><picker mode="date" bindchange="onFeedDate" value="{{feedDate}}"><view class="picker">{{feedDate || '选择日期'}}</view></picker></view>
      <view class="form-group"><text class="label">粮名</text><input value="{{feedFoodName}}" bindinput="onInput" data-field="feedFoodName" placeholder="如：渴望"/></view>
      <view class="form-group"><text class="label">克数</text><input value="{{feedGrams}}" bindinput="onInput" data-field="feedGrams" type="number" placeholder="g"/></view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">便便成形度</text><picker bindchange="onFeedStool" value="{{feedStool}}" range="{{stoolOptions}}"><view class="picker">{{feedStoolLabel ? stoolOptions[feedStoolLabel-1] : '-'}}</view></picker></view>
      <view class="form-group"><text class="label">泪痕量</text><picker bindchange="onFeedTear" value="{{feedTear}}" range="{{tearOptions}}"><view class="picker">{{feedTearLabel ? tearOptions[feedTearLabel-1] : '-'}}</view></picker></view>
      <view class="form-group"><text class="label">皮肤状态</text><picker bindchange="onFeedSkin" value="{{feedSkin}}" range="{{skinOptions}}"><view class="picker">{{feedSkinLabel ? skinOptions[feedSkinLabel-1] : '-'}}</view></picker></view>
    </view>
    <button class="btn-sm" bindtap="onSubmitFeed">📝 记录</button>
    <view wx:for="{{feedList}}" wx:key="id" class="diary-row">
      <text>{{item.date}} {{item.foodName}} {{item.grams}}g</text>
      <button class="btn-sm btn-danger" bindtap="onDeleteFeed" data-id="{{item.id}}" size="mini">删除</button>
    </view>
  </view>
</view>

<!-- 疫苗面板 -->
<view wx:if="{{currentTab==='vaccination'}}" class="tab-panel">
  <view class="card">
    <text class="h2">💉 疫苗日记</text>
    <text style="font-size:13px;color:var(--text-light);margin-bottom:12px">{{vaxHint}}</text>
    <view wx:for="{{vaxAlerts}}" wx:key="text" class="alert-card {{item.type==='danger'?'alert-danger':'alert-warning'}}">
      <text>{{item.type==='danger'?'🔴':'⚠'}} {{item.text}}</text>
    </view>
    <view wx:if="{{vaxAlerts.length===0}}" style="color:var(--text-light);padding:8px">🎉 近期没有待办疫苗</view>
    <view class="form-row">
      <view class="form-group"><text class="label">接种日期</text><picker mode="date" bindchange="onVaxDate" value="{{vaxDate}}"><view class="picker">{{vaxDate||'选择日期'}}</view></picker></view>
      <view class="form-group"><text class="label">疫苗名称</text><input value="{{vaxName}}" bindinput="onInput" data-field="vaxName" placeholder="如：狂犬" maxlength="50"/></view>
    </view>
    <view class="form-row">
      <view class="form-group"><text class="label">下次接种</text><picker mode="date" bindchange="onVaxNext" value="{{vaxNextDue}}"><view class="picker">{{vaxNextDue||'留空=一次性'}}</view></picker></view>
      <view class="form-group"><text class="label">兽医</text><input value="{{vaxVet}}" bindinput="onInput" data-field="vaxVet" placeholder="可选"/></view>
    </view>
    <button class="btn-sm" bindtap="onSubmitVax">📝 记录</button>
    <view wx:for="{{vaxList}}" wx:key="id" class="diary-row">
      <text>{{item.date}} {{item.vaccineName}} {{item.daysBadge}} {{item.vet}}</text>
      <button class="btn-sm btn-danger" bindtap="onDeleteVax" data-id="{{item.id}}" size="mini">删除</button>
    </view>
  </view>
</view>
